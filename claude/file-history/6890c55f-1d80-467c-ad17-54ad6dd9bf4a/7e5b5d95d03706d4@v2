function UaePassIcon() {
  return (
    <svg
      aria-hidden="true"
      width="21"
      height="20"
      viewBox="0 0 21 20"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <rect x="0.5" width="20" height="20" rx="3" fill="#00AEEF" />
      <path
        d="M5.5 10h10M7.5 6.5h6M7.5 13.5h6"
        stroke="white"
        strokeWidth="1.5"
        strokeLinecap="round"
      />
