export interface SignUpRequest {
  password: string;
  firstName: string;
  lastName: string;
  patronymic?: string;
  phoneOtpId: string;
  emailOtpId: string;
  role: UserRole;
  phone: string;
}

export interface SendOtpRequest {
  email?: string;
  phone?: string;
  type: OtpType;
  mediaType?: MediaType;
}

export interface VerifyOtpRequest extends SendOtpRequest {
  otp: string;
  mediaType: MediaType;
}

export interface SignInRequest {
  email: string;
  password: string;
}

export interface ChangeTempPasswordRequest {
  email: string;
  newPassword: string;
  session: string;
}

export interface RefreshTokenRequest {
  refreshToken: string;
  accessToken: string;
}

export interface SignOutRequest {
  accessToken: string;
}

export interface ForgotPasswordRequest {
  email?: string;
  phone?: string;
  mediaType: MediaType;
}

export interface ConfirmForgotPasswordRequest {
  otpId: string;
  newPassword: string;
}

export interface AuthTokens {
  accessToken: string;
  refreshToken: string;
  idToken: string;
}

export interface SignInSuccessResponse {
  status: "SUCCESS";
  payload: AuthTokens;
}

export interface SignInChallengeResponse {
  status: "CHALLENGE";
  challengeName: "NEW_PASSWORD_REQUIRED";
  session: string;
  challengeParameters: Record<string, unknown>;
  message: string;
}

export interface SignInFailedResponse {
  status: "FAILED";
  message: string;
}

export type SignInResponse =
  | SignInSuccessResponse
  | SignInChallengeResponse
  | SignInFailedResponse;

export interface SendOtpResponse {
  status: "SUCCESS";
  types: OtpType[];
  validity: number;
  resendAfter: number;
  message: string;
  otp?: string;
}

export interface OtpEntity {
  id: string;
  approved: boolean;
  updatedAt: string;
}

export interface ForgotPasswordResponse {
  status: "SUCCESS";
  message: string;
  otp?: string;
}

export interface ConfirmForgotPasswordResponse {
  status: "SUCCESS";
  message: string;
}

export interface RefreshTokenResponse {
  accessToken: string;
  refreshToken: string;
  idToken: string;
}

export interface OAuthGoogleRequest {
  idToken: string;
}

export interface OAuthAppleRequest {
  identityToken: string;
  firstName?: string;
  lastName?: string;
}
