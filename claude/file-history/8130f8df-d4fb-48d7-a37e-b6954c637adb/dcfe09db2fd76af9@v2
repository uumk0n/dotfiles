import { ApiProperty } from '@nestjs/swagger';
import {
  IsEmail,
  IsEnum,
  IsNotEmpty,
  IsOptional,
  IsPhoneNumber,
  IsString,
  IsUUID,
  ValidateIf,
} from 'class-validator';
import { MediaType, OtpType, UserRole } from '@/db';

export class SignInRequestDto {
  @ApiProperty()
  @IsEmail()
  email: string;

  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  password: string;
}

export class ResendConfirmationCodeDto {
  @ApiProperty()
  @IsEmail()
  email: string;
}

export class ChangeTempPasswordRequestDto {
  @ApiProperty()
  @IsEmail()
  email: string;

  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  newPassword: string;

  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  session: string;
}

export class RefreshTokenRequestDto {
  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  refreshToken: string;

  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  accessToken: string;
}

export class OAuthQuery {
  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  redirect_uri: string;
}

export class OAuthCallbackQuery {
  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  code: string;

  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  state: string;
}

export class GetOAuthTokensDto {
  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  code: string;
}

export class SignOutRequestDto {
  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  accessToken: string;
}

export class SignUpRequestDto {
  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  password: string;

  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  firstName: string;

  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  lastName: string;

  @ApiProperty({ required: false })
  @IsString()
  @IsOptional()
  patronymic?: string;

  @ApiProperty()
  @IsUUID()
  phoneOtpId: string;

  @ApiProperty()
  @IsUUID()
  emailOtpId: string;

  @ApiProperty()
  @IsEnum([UserRole.Bidder, UserRole.Seller, UserRole.Retailer])
  role: UserRole;
}

export class SendOtpDto {
  @ApiProperty()
  @IsOptional()
  @IsEmail()
  email?: string;

  @ApiProperty()
  @IsPhoneNumber()
  @IsOptional()
  phone?: string;

  @ApiProperty()
  @IsEnum(OtpType)
  type: OtpType;

  // Not required when type === SIGN_UP and both email + phone are provided
  // (both channels are handled in a single request).
  @ApiProperty({ required: false })
  @ValidateIf(
    (o: SendOtpDto) => !(o.type === OtpType.SignUp && !!o.email && !!o.phone),
  )
  @IsEnum(MediaType)
  mediaType?: MediaType;
}

export class ForgotPasswordDto {
  @ApiProperty({ required: false })
  @ValidateIf((o) => o.mediaType === MediaType.Email)
  @IsEmail()
  @IsNotEmpty()
  email?: string;

  @ApiProperty({ required: false })
  @ValidateIf((o) => o.mediaType === MediaType.Phone)
  @IsPhoneNumber()
  @IsNotEmpty()
  phone?: string;

  @ApiProperty({ enum: MediaType })
  @IsEnum(MediaType)
  mediaType: MediaType;
}

export class ConfirmForgotPasswordDto {
  @ApiProperty()
  @IsUUID()
  otpId: string;

  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  newPassword: string;
}

export class VerifyOtpDto extends SendOtpDto {
  @ApiProperty()
  @IsString()
  @IsNotEmpty()
  otp: string;
}

export class PhoneExistsRequestDto {
  @ApiProperty()
  @IsPhoneNumber()
  phone: string;
}

export class EmailExistsRequestDto {
  @ApiProperty()
  @IsEmail()
  email: string;
}

export class GoogleSignInDto {
  @ApiProperty({ description: 'Google ID token from mobile SDK' })
  @IsString()
  @IsNotEmpty()
  idToken: string;
}

export class AppleSignInDto {
  @ApiProperty({ description: 'Apple identity token from Sign In with Apple' })
  @IsString()
  @IsNotEmpty()
  identityToken: string;

  @ApiProperty({
    required: false,
    description: 'First name (only available on first sign-in)',
  })
  @IsString()
  @IsOptional()
  firstName?: string;

  @ApiProperty({
    required: false,
    description: 'Last name (only available on first sign-in)',
  })
  @IsString()
  @IsOptional()
  lastName?: string;
}
