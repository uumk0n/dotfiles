    if (filter === "active") return ACTIVE_TICKET_STATUSES;
    if (filter === "archive") return ARCHIVE_TICKET_STATUSES;
    return;
  }
  const statuses = getStatuses();

  const { data, isLoading } = useTickets({ statuses }, isAuthenticated);

  const tickets = data?.data ?? [];
  const ticketCount = data?.total ?? 0;

  const raiseTicketIcon = (
    <svg aria-hidden="true" fill="none" height="14" viewBox="0 0 14 14" width="14">
      <path d="M7 1v12M1 7h12" stroke="currentColor" strokeLinecap="round" strokeWidth="1.5" />
    </svg>
  );

  return (
    <>
    <div className="flex flex-col">
      <div className="lg:min-h-[950px]">
        {/* Page header */}
        <div className="mt-8 flex items-center justify-between gap-4 sm:items-start">
          <h1 className="font-extralight font-new-serif text-4xl text-[#44403C] leading-[120%]">
            Support
          </h1>
          {/* Mobile: navigate to create page */}
          <Link
            className="inline-flex h-10 w-fit items-center gap-2 rounded border border-[#44403C] bg-transparent px-4 font-new-sans text-[#44403C] text-sm transition-colors hover:bg-[#EDE9E3] sm:hidden"
            href={APP_ROUTES.TICKETS.CREATE}
          >
            Raise Ticket
            {raiseTicketIcon}
          </Link>
          {/* Desktop: open drawer */}
          <button
            type="button"
            onClick={() => setIsDrawerOpen(true)}
            className="hidden h-10 w-fit items-center gap-2 rounded border border-[#44403C] bg-transparent px-4 font-new-sans text-[#44403C] text-sm transition-colors hover:bg-[#EDE9E3] sm:inline-flex"
          >
            Raise Ticket
            {raiseTicketIcon}
          </button>
        </div>

        <Separator className="my-10 hidden lg:block" />

        {/* Count + filter */}
        <div className="my-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between lg:my-10">
          <div className="flex flex-col gap-0.5">
            <p className="font-medium font-new-sans text-[#44403C]">
              {isAuthenticated ? ticketCount : 0} Support Requests
            </p>
            <p className="font-new-sans text-[#A8A29E] text-sm">
              This is a record of all your Support Requests
            </p>
          </div>
          <Select
            disabled={!isAuthenticated}
            onValueChange={(val) => setFilter(val as FilterValue)}
            value={filter}
          >
            <SelectTrigger className="h-10 w-full rounded border border-[#D6D3D1] bg-[#F5F3EF] font-new-sans text-[#44403C] text-sm max-lg:hidden sm:w-[180px]">
              <SelectValue />
            </SelectTrigger>
            <SelectContent>
              <SelectItem value="all">All Tickets</SelectItem>
              <SelectItem value="active">Active</SelectItem>
              <SelectItem value="archive">Archive</SelectItem>
            </SelectContent>
          </Select>
        </div>

        {/* Ticket list area */}
        <div className="mb-8 overflow-hidden rounded-xl border border-[#D6D3D1] bg-[#F5F3EF] lg:mb-16">
          <TicketListContent
            isAuthenticated={isAuthenticated}
            isLoading={isSessionLoading || (isAuthenticated && isLoading)}
            onTicketClick={(id) => router.push(`/support/${id}`)}
            tickets={tickets}
          />
        </div>
      </div>

      {/* Questions or enquiries — full bleed */}
      <div className="-mb-4 min-[1172px]:-mb-8 mr-[calc(-50vw+50%)] ml-[calc(-50vw+50%)]">
        <SupportSection />
      </div>
    </div>

    <Sheet open={isDrawerOpen} onOpenChange={setIsDrawerOpen}>
      <SheetContent
        side="right"
        hideCloseButton
        className="new-design flex w-full max-w-[480px] flex-col gap-0 overflow-y-auto bg-[#F5F3EF] p-0"
      >
        <div className="px-6 pt-6 pb-5">
          <BackButton label="Back" onClick={() => setIsDrawerOpen(false)} />
          <h2 className="mt-5 font-light font-new-serif text-[#44403C] text-[2rem] leading-[120%]">
            Raise a Support Ticket
          </h2>
          <p className="mt-2 font-new-sans text-[#A8A29E] text-sm">
            Share enough details to get your issue resolved. Our team will evaluate your request and will address it soon.
          </p>
          <div className="mt-5 border-[#D6D3D1] border-t" />
        </div>
        <div className="flex-1 px-6 pb-8">
          <CreateTicketForm
            isGuest={!isAuthenticated}
            onSuccess={handleDrawerSuccess}
            onCancel={() => setIsDrawerOpen(false)}
          />
        </div>
      </SheetContent>
    </Sheet>
    </>
  );
}

