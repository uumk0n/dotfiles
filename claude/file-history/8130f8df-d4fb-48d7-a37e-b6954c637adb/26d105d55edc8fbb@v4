import { Module } from '@nestjs/common';
import { ConfigModule } from '@nestjs/config';
import { JwtModule } from '@nestjs/jwt';

import { UserModule } from '@/modules/user';
import { OtpModule } from '@/modules/otp';
import { NotificationModule } from '@/modules/notification';
import { StorageService } from '@/modules/file/services/storage.service';
import { env } from '@/env';

import { AuthService, CognitoService, SocialAuthService } from './services';

@Module({
  imports: [
    ConfigModule,
    UserModule,
    OtpModule,
    NotificationModule,
    JwtModule.register({
      secret: env.JWT_SECRET,
      signOptions: { expiresIn: '1h' },
    }),
  ],
  providers: [AuthService, CognitoService, SocialAuthService, StorageService],
  exports: [AuthService, CognitoService, SocialAuthService, JwtModule],
})
export class AuthModule {}
