import { BuybackType } from '@/db';
import {
  NotificationContentType,
  NotificationData,
  NotificationMedia,
  NotificationType,
} from '../consts';

type Data = NotificationData<NotificationType.QuoteRequestAdminNotification>;

const BUYBACK_TYPE_LABEL: Record<BuybackType, string> = {
  [BuybackType.Buyback]: 'Sale with Buyback',
  [BuybackType.DirectSale]: 'Direct Sale',
};

export const QUOTE_REQUEST_ADMIN_CONTENT: NotificationContentType = {
  [NotificationMedia.Email]: (data: Data) => ({
    subject: 'LuxFlow: New offer received',
    text: [
      'New offer received.',
      `Item: ${BUYBACK_TYPE_LABEL[data.buybackType]}`,
      [data.asset.brandName, data.asset.referenceNumber].filter(Boolean).join(' '),
      data.asset.condition,
    ]
      .filter(Boolean)
      .join('\n'),
  }),
  [NotificationMedia.InApp]: (data: Data) => ({
    title: 'New Offer Received',
    body: `${BUYBACK_TYPE_LABEL[data.buybackType]} – ${data.asset.categoryName}`,
  }),
  [NotificationMedia.Phone]: (data: Data) =>
    [
      'New offer received.',
      `Item: ${BUYBACK_TYPE_LABEL[data.buybackType]}`,
      [data.asset.brandName, data.asset.referenceNumber].filter(Boolean).join(' '),
      data.asset.condition,
    ]
      .filter(Boolean)
      .join('\n'),
};
